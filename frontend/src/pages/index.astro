  <!-- Audio oculto -->
  <audio id="audio" preload="metadata"></audio>

</Layout>

<!-- ═══════════════════════════════════════════
     JAVASCRIPT
═══════════════════════════════════════════ -->
<script define:vars={{ canciones, fotos, dedicatoria }}>

  // ───────────────────────────────────────────
  // BASE DE DATOS DE POEMAS Y DEDICATORIAS PARA LESLY
  // ───────────────────────────────────────────
  const POEMAS = [
    {
      poema: `Quiero hacer contigo
lo que la primavera hace con los cerezos.`,
      dedicatoria: `Para Lesly, el motivo de mi primavera eterna.`,
      autor: "Pablo Neruda"
    },
    {
      poema: `¿Qué es poesía? dices mientras clavas
en mi pupila tu pupila azul.
¿Qué es poesía? ¿Y tú me lo preguntas?
Poesía... eres tú.`,
      dedicatoria: `Lesly, eres mi poema preferido y mi inspiración diaria.`,
      autor: "Gustavo Adolfo Bécquer"
    },
    {
      poema: `Mi táctica es mirarte
aprender cómo sos
quererte como sos.

Mi estrategia es que un día cualquiera
no sé cómo ni sé con qué pretexto
por fin me necesites.`,
      dedicatoria: `Para Lesly, construyendo a tu lado nuestro lugar en el mundo.`,
      autor: "Mario Benedetti"
    },
    {
      poema: `Amor de mis entrañas, viva muerte,
en vano espero tu palabra escrita
y pienso, con la flor que se marchita,
que si vivo sin mí quiero perderte.`,
      dedicatoria: `Lesly, cada palabra tuya llena de luz mi vida entera.`,
      autor: "Federico García Lorca"
    },
    {
      poema: `Tus ojos son la patria del relámpago y de la lágrima,
silencio que habla,
tempestades sin viento, mar sin olas,
pájaros presos, doradas fieras adormecidas...`,
      dedicatoria: `Lesly, en tu mirada encuentro el refugio más dulce del mundo.`,
      autor: "Octavio Paz"
    },
    {
      poema: `Tu alma es el color del tiempo de otoño;
tus ojos brillan como la estrella del atardecer;
en tu sonrisa habita el suspiro de la mañana.`,
      dedicatoria: `Para mi estrella más brillante y hermosa, Lesly.`,
      autor: "Antonio Machado"
    },
    {
      poema: `Para amar es necesario un alma libre,
que vuele alto y dibuje en el viento
las notas más bellas de nuestra canción.`,
      dedicatoria: `Lesly, tu libertad, tu sonrisa y tu luz me enamoran cada día más.`,
      autor: "Emily Dickinson"
    },
    {
      poema: `Te quiero a las diez de la mañana, y a las once,
y a las doce del día.
Te quiero con toda mi alma y con todo mi cuerpo...`,
      dedicatoria: `Lesly, te elijo y te quiero en cada segundo de mis días.`,
      autor: "Jaime Sabines"
    },
    {
      poema: `Una tarde la princesa
vio una estrella aparecer;
la princesa era traviesa
y la quiso ir a coger...`,
      dedicatoria: `Lesly, mi pequeña princesa que hace todo mi mundo mágico.`,
      autor: "Rubén Darío"
    },
    {
      poema: `Hay besos que pronuncian por sí solos
la sentencia de amor condenatoria,
hay besos que se dan con la mirada,
hay besos que se dan con la memoria...`,
      dedicatoria: `Cada beso y cada recuerdo junto a ti es un tesoro eterno, Lesly.`,
      autor: "Gabriela Mistral"
    }
  ];

  // Titles and short descriptions for our 3D Deck of Cards
  const DETALLES_CARTAS = [
    { titulo: "Primer Beso", desc: "El instante en que el tiempo se detuvo." },
    { titulo: "Tu Sonrisa", desc: "La luz que ilumina mis días más grises." },
    { titulo: "Caminos", desc: "Andar de tu mano es mi rumbo favorito." },
    { titulo: "Tu Voz", desc: "Mi sintonía y melodía preferida." },
    { titulo: "Miradas", desc: "Donde no hacen falta las palabras." },
    { titulo: "Abrazos", desc: "El único lugar donde me siento a salvo." }
  ];

  // ───────────────────────────────────────────
  // DIBUJAR ROSAS, FLORES Y CORAZONES FLOTANTES CON LETRAS (EXCLUYE LA COMBI XO/OX)
  // ───────────────────────────────────────────
  const COLORES  = ['#f472b6','#c084fc','#fb7185','#818cf8','#f9a8d4','#fbbf24','#a78bfa','#e879f9'];
  const contenedor = document.getElementById('flotantes');

  function crearLetra() {
    const el = document.createElement('div');
    
    // 60% de probabilidades de renderizar un SVG premium de rosas/flores, 40% de letras y otros símbolos unicode
    const isSVG = Math.random() < 0.6;
    if (isSVG) {
      const svgs = [
        // Rosa vectorizada elegante con pétalo
        `<svg viewBox="0 0 24 24" class="w-6 h-6 fill-rose-500/25 drop-shadow-[0_0_8px_rgba(244,114,182,0.35)]"><path d="M12 2C9 2 4 6 4 11c0 5.25 4.5 9 8 9s8-3.75 8-9c0-5-5-9-8-9z"/></svg>`,
        // Flor silvestre delicada
        `<svg viewBox="0 0 24 24" class="w-5 h-5 fill-pink-500/20 drop-shadow-[0_0_8px_rgba(244,114,182,0.3)]"><path d="M12 2a3 3 0 00-3 3 3 3 0 00-3-3 3 3 0 00-3 3 3 3 0 003 3 3 3 0 00-3 3 3 3 0 003 3 3 3 0 003-3 3 3 0 003 3 3 3 0 003-3 3 3 0 00-3-3 3 3 0 003-3 3 3 0 00-3-3 3 3 0 00-3 3 3 3 0 00-3-3z"/></svg>`,
        // Corazón glowing
        `<svg viewBox="0 0 24 24" class="w-4 h-4 fill-rose-600/25 drop-shadow-[0_0_6px_rgba(244,114,182,0.35)]"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>`,
        // Destello / Brillo
        `<svg viewBox="0 0 24 24" class="w-4 h-4 fill-purple-400/25 drop-shadow-[0_0_6px_rgba(168,85,247,0.3)]"><path d="M9.813 15.904L9 21l-.813-5.096L3.096 15.187 8.192 14.37 9 9.278l.808 5.093 5.096.817-5.091.816z"/></svg>`
      ];
      el.innerHTML = svgs[Math.floor(Math.random() * svgs.length)];
    } else {
      // Símbolos y letras puras: ¡Excluimos la x, o, X y O para prevenir cualquier combinación de "xo" u "ox"!
      const unicodeSymbols = [
        '✿', '❀', '⚘', '✨', '🍃', '★', '♡', '♥',
        'A','B','C','D','E','F','G','H','I','J','K','L','M','N','P','Q','R','S','T','U','V','W','Y','Z',
        'a','b','c','d','e','f','g','h','i','j','k','l','m','n','p','q','r','s','t','u','v','w','y','z'
      ];
      el.textContent = unicodeSymbols[Math.floor(Math.random() * unicodeSymbols.length)];
    }
    
    const dur   = Math.random() * 12 + 10;
    const delay = Math.random() * 3;
    el.style.cssText = `
      position:absolute;
      left:${Math.random() * 100}%;
      bottom:-60px;
      font-size:${Math.random() * 1.6 + 0.8}rem;
      color:${COLORES[Math.floor(Math.random() * COLORES.length)]};
      opacity:0;
      animation:floatUp ${dur}s ${delay}s linear forwards;
      pointer-events:none;
      user-select:none;
      transform: rotate(${Math.random() * 360}deg);
    `;
    contenedor.appendChild(el);
    setTimeout(() => el.remove(), (dur + delay + 1) * 1000);
  }

  // Primeras letras inmediatas
  for (let i = 0; i < 25; i++) crearLetra();
  setInterval(crearLetra, 350);


  // ───────────────────────────────────────────
  // CORAZONES FLOTANTES AL HACER CLIC EN CUALQUIER PARTE
  // ───────────────────────────────────────────
  document.addEventListener('click', (e) => {
    // Evitar disparar en botones, sobre de carta, enlaces, tarjetas de fotos o mapa de aventuras
    if (e.target.closest('button') || e.target.closest('a') || e.target.closest('.stack-card') || e.target.closest('.envelope-container') || e.target.closest('.adventure-card')) return;

    const heart = document.createElement('div');
    heart.className = 'fixed pointer-events-none z-50 text-purple-500/80';
    heart.style.left = `${e.clientX - 10}px`;
    heart.style.top = `${e.clientY - 10}px`;
    
    // SVG de corazón
    heart.innerHTML = `
      <svg class="w-6 h-6 animate-pulse" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
      </svg>
    `;
    
    document.body.appendChild(heart);

    // Animación personalizada vía JS Web Animations API
    const xOffset = (Math.random() - 0.5) * 120; // desplazamiento horizontal
    const keyframes = [
      { transform: 'translate(0, 0) scale(1)', opacity: 0.8 },
      { transform: `translate(${xOffset}px, -150px) scale(1.6)`, opacity: 0 }
    ];
    
    heart.animate(keyframes, {
      duration: 1200,
      easing: 'ease-out',
      fill: 'forwards'
    });

    setTimeout(() => heart.remove(), 1200);
  });


  // ───────────────────────────────────────────
  // REPRODUCTOR CON LETRAS SINCRONIZADAS
  // ───────────────────────────────────────────
  const audio        = document.getElementById('audio');
  const btnPlay      = document.getElementById('btn-play');
  const btnPrev      = document.getElementById('btn-prev');
  const btnNext      = document.getElementById('btn-next');
  const barraFill    = document.getElementById('barra-fill');
  const barraProg    = document.getElementById('barra-prog');
  const tActual      = document.getElementById('t-actual');
  const tTotal       = document.getElementById('t-total');
  const lyricDisplay = document.getElementById('lyric-display');
  const albumArt     = document.getElementById('album-art');
  const albumSvg     = document.getElementById('album-svg');
  const songTitle    = document.getElementById('song-title');
  const songArtist   = document.getElementById('song-artist');
  const playIconWrapper = document.getElementById('play-icon-wrapper');

  let idx     = 0;
  let playing = false;
  let ultimaLetra = '';

  const SVG_PLAY  = `<svg class="w-6 h-6 text-white translate-x-[2px]" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>`;
  const SVG_PAUSE = `<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>`;

  function fmt(s) {
    if (!s || isNaN(s)) return '0:00';
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return `${m}:${sec.toString().padStart(2,'0')}`;
  }

  function cargarCancion(i) {
    const c = canciones[i];
    audio.src   = c.src;
    songTitle.textContent  = c.titulo;
    songArtist.textContent = c.artista;

    if (c.cover) {
      albumArt.style.backgroundImage = `url(${c.cover})`;
      albumArt.style.backgroundSize  = 'cover';
      albumSvg.style.display = 'none';
    } else {
      albumArt.style.backgroundImage = '';
      albumSvg.style.display = '';
    }
  }

  function actualizarLetra() {
    const c = canciones[idx];
    const t = audio.currentTime;
    let letra = c.letras[0]?.texto ?? '';
    for (const l of c.letras) {
      if (t >= l.t) letra = l.texto;
    }
    if (letra !== ultimaLetra) {
      ultimaLetra = letra;
      // Re-trigger animation
      lyricDisplay.classList.remove('lyric-line');
      void lyricDisplay.offsetWidth;
      lyricDisplay.classList.add('lyric-line');
      lyricDisplay.textContent = letra;
    }
  }

  function playTrack() {
    audio.play().catch(() => {});
    playIconWrapper.innerHTML = SVG_PAUSE;
    albumArt.classList.add('spinning', 'pulsing-beat');
    playing = true;
  }

  function pauseTrack() {
    audio.pause();
    playIconWrapper.innerHTML = SVG_PLAY;
    albumArt.classList.remove('spinning', 'pulsing-beat');
    playing = false;
  }

  btnPlay.addEventListener('click', () => {
    if (audio.paused) {
      playTrack();
    } else {
      pauseTrack();
    }
  });

  btnNext.addEventListener('click', () => {
    idx = (idx + 1) % canciones.length;
    cargarCancion(idx);
    if (playing) {
      playTrack();
    }
  });

  btnPrev.addEventListener('click', () => {
    if (audio.currentTime > 3) { audio.currentTime = 0; return; }
    idx = (idx - 1 + canciones.length) % canciones.length;
    cargarCancion(idx);
    if (playing) {
      playTrack();
    }
  });

  audio.addEventListener('timeupdate', () => {
    const pct = (audio.currentTime / audio.duration) * 100 || 0;
    barraFill.style.width = `${pct}%`;
    tActual.textContent   = fmt(audio.currentTime);
    tTotal.textContent    = fmt(audio.duration);
    actualizarLetra();
  });

  audio.addEventListener('ended', () => {
    idx = (idx + 1) % canciones.length;
    cargarCancion(idx);
    playTrack();
  });

  barraProg.addEventListener('click', (e) => {
    const rect = barraProg.getBoundingClientRect();
    audio.currentTime = ((e.clientX - rect.left) / rect.width) * audio.duration;
  });

  cargarCancion(0);


  // ───────────────────────────────────────────
  // INTERACCIÓN DE APERTURA DEL SOBRE DE CARTA
  // ───────────────────────────────────────────
  const sobre = document.getElementById('sobre');
  const sello = document.getElementById('sello');

  sobre.addEventListener('click', (e) => {
    e.stopPropagation(); // Evitar disparar corazones de fondo al abrir/cerrar la carta
    sobre.classList.toggle('open');
    if (sobre.classList.contains('open')) {
      sello.style.transform = 'scale(0) rotate(180deg)';
      sello.style.opacity = '0';
      // ¡AUTO-PLAY DE LA MÚSICA CON EFECTO DE BEAT AUTOMÁTICO AL ABRIR LA CARTA!
      if (audio.paused) {
        playTrack();
      }
    } else {
      sello.style.transform = 'scale(1) rotate(0deg)';
      sello.style.opacity = '1';
    }
  });


  // ───────────────────────────────────────────
  // CONTADOR DE TIEMPO TRANSCURRIDO (ANIVERSARIO)
  // ───────────────────────────────────────────
  const cDias  = document.getElementById('c-dias');
  const cHoras = document.getElementById('c-horas');
  const cMins  = document.getElementById('c-mins');
  const cSegs  = document.getElementById('c-segs');

  function actualizarContador() {
    const fechaInicio = new Date(dedicatoria.fechaInicio + 'T00:00:00');
    const ahora = new Date();
    const diferencia = ahora - fechaInicio;

    if (diferencia < 0) {
      cDias.textContent  = "00";
      cHoras.textContent = "00";
      cMins.textContent  = "00";
      cSegs.textContent  = "00";
      return;
    }

    const msPorDia   = 1000 * 60 * 60 * 24;
    const msPorHora  = 1000 * 60 * 60;
    const msPorMin   = 1000 * 60;
    const msPorSeg   = 1000;

    const dias  = Math.floor(diferencia / msPorDia);
    const horas = Math.floor((diferencia % msPorDia) / msPorHora);
    const mins  = Math.floor((diferencia % msPorHora) / msPorMin);
    const segs  = Math.floor((diferencia % msPorMin) / msPorSeg);

    cDias.textContent  = dias.toString().padStart(2, '0');
    cHoras.textContent = horas.toString().padStart(2, '0');
    cMins.textContent  = mins.toString().padStart(2, '0');
    cSegs.textContent  = segs.toString().padStart(2, '0');
  }

  actualizarContador();
  setInterval(actualizarContador, 1000);


  // ───────────────────────────────────────────
  // MODAL E INTERACCIÓN DE POEMAS
  // ───────────────────────────────────────────
  const modal          = document.getElementById('modal-poema');
  const modalClose     = document.getElementById('modal-close');
  const modalIcon      = document.getElementById('modal-icon');
  const modalTexto     = document.getElementById('modal-poema-texto');
  const modalDedic     = document.getElementById('modal-dedicatoria');
  const modalAutor     = document.getElementById('modal-autor');

  function abrirPoema(i, svgHtml) {
    const data = POEMAS[i % POEMAS.length];
    modalIcon.innerHTML     = svgHtml;
    modalTexto.textContent  = data.poema;
    modalDedic.textContent  = data.dedicatoria;
    modalAutor.textContent  = `— ${data.autor}`;
    
    // Abrir con animación
    modal.classList.remove('opacity-0', 'pointer-events-none');
    modal.querySelector('div').classList.remove('scale-95');
    modal.querySelector('div').classList.add('scale-100');
  }

  function cerrarModal() {
    modal.classList.add('opacity-0', 'pointer-events-none');
    modal.querySelector('div').classList.remove('scale-100');
    modal.querySelector('div').classList.add('scale-95');
  }

  modalClose.addEventListener('click', cerrarModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) cerrarModal();
  });


  // ───────────────────────────────────────────
  // 3D STACK CAROUSEL DE CARTAS ROMÁNTICAS
  // ───────────────────────────────────────────
  const galeriaStack = document.getElementById('galeria-stack');

  // 6 SVGs premium para las cartas del Stack 3D
  const SVG_STACK = [
    // 1. Heart
    `<svg class="w-12 h-12 text-purple-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>`,
    // 2. Star
    `<svg class="w-12 h-12 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>`,
    // 3. Sparkles
    `<svg class="w-12 h-12 text-fuchsia-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.4 4.8 5.6.8-4 4 1 5.4-5-2.8-5 2.8 1-5.4-4-4 5.6-.8z"/></svg>`,
    // 4. Music
    `<svg class="w-12 h-12 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 10l12-3M9 14a3 3 0 11-6 0 3 3 0 016 0zm12 2a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    // 5. Camera
    `<svg class="w-12 h-12 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/></svg>`,
    // 6. Gift
    `<svg class="w-12 h-12 text-fuchsia-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V6a2 2 0 10-2 2h2zm0 0H4v13a2 2 0 002 2h12a2 2 0 002-2V8H12z"/></svg>`
  ];

  const gradients = [
    'from-pink-500/10 to-purple-500/10 hover:from-pink-500/15 hover:to-purple-500/15',
    'from-rose-500/10 to-pink-500/10 hover:from-rose-500/15 hover:to-pink-500/15',
    'from-purple-500/10 to-indigo-500/10 hover:from-purple-500/15 hover:to-indigo-500/15',
    'from-indigo-500/10 to-blue-500/10 hover:from-indigo-500/15 hover:to-blue-500/15',
    'from-amber-500/10 to-rose-500/10 hover:from-amber-500/15 hover:to-rose-500/15',
    'from-fuchsia-500/10 to-pink-500/10 hover:from-fuchsia-500/15 hover:to-pink-500/15'
  ];

  // Instanciar las tarjetas en el DOM
  SVG_STACK.forEach((svgContent, i) => {
    const cardData = DETALLES_CARTAS[i % DETALLES_CARTAS.length];
    
    const div = document.createElement('div');
    div.className = `stack-card bg-gradient-to-br ${gradients[i % gradients.length]}`;
    div.dataset.index = i;
    
    div.innerHTML = `
      <div class="flex flex-col items-center gap-1 w-full">
        <span class="text-xs text-purple-400/50 uppercase tracking-widest font-semibold">Recuerdo ${i + 1} de ${SVG_STACK.length}</span>
        <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center border border-white/5 shadow-inner mt-4">
          ${svgContent}
        </div>
      </div>
      
      <div class="flex flex-col items-center mb-4">
        <h4 class="stack-card-title font-sans">${cardData.titulo}</h4>
        <p class="stack-card-desc font-sans">${cardData.desc}</p>
      </div>

      <!-- Icono decorativo de corazón -->
      <svg class="w-6 h-6 text-white/10" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
      </svg>
    `;

    // Al hacer clic en la de enfrente, abre el poema.
    div.addEventListener('click', (e) => {
      e.stopPropagation();
      if (div.classList.contains('state-0')) {
        abrirPoema(i, svgContent);
      }
    });

    galeriaStack.appendChild(div);
  });

  // ───────────────────────────────────────────
  // MANEJADOR DE ESTADOS DEL STACK 3D (TINDER CAROUSEL)
  // ───────────────────────────────────────────
  let stackIndex = 0;
  const totalCards = SVG_STACK.length;

  function renderStack() {
    const cards = document.querySelectorAll('.stack-card');
    cards.forEach((card) => {
      const idx = parseInt(card.dataset.index);
      
      // Limpiar clases de animación y estados
      card.classList.remove('state-0', 'state-1', 'state-2', 'state-hidden', 'exit-left', 'exit-right');

      // Calcular la posición relativa en la pila circular
      let relativePos = (idx - stackIndex) % totalCards;
      if (relativePos < 0) relativePos += totalCards;

      if (relativePos === 0) {
        card.classList.add('state-0');
      } else if (relativePos === 1) {
        card.classList.add('state-1');
      } else if (relativePos === 2) {
        card.classList.add('state-2');
      } else {
        card.classList.add('state-hidden');
      }
    });
  }

  function nextCard() {
    const cards = document.querySelectorAll('.stack-card');
    const currentFrontCard = Array.from(cards).find(c => parseInt(c.dataset.index) === stackIndex);
    
    if (currentFrontCard) {
      // Animación de salida volando hacia la izquierda
      currentFrontCard.classList.add('exit-left');
      
      setTimeout(() => {
        stackIndex = (stackIndex + 1) % totalCards;
        renderStack();
      }, 350);
    }
  }

  function prevCard() {
    stackIndex = (stackIndex - 1 + totalCards) % totalCards;
    renderStack();
  }

  document.getElementById('btn-stack-next').addEventListener('click', (e) => {
    e.stopPropagation();
    nextCard();
  });

  document.getElementById('btn-stack-prev').addEventListener('click', (e) => {
    e.stopPropagation();
    prevCard();
  });

  // Renderizar la pila por primera vez
  renderStack();
</script>

<script is:inline>
  // ───────────────────────────────────────────
  // MANEJADOR DE AVENTURAS INTERACTIVAS CON GLOW EN EL CAMINO (MAPA DE RUTA)
  // ───────────────────────────────────────────
  function toggleAdventure(card) {
    card.classList.toggle('checked');
    const badge = card.querySelector('.adventure-badge');
    const row = card.closest('.adventure-path-row');
    
    if (card.classList.contains('checked')) {
      badge.textContent = "¡Lo logramos! ✦";
      if (row) {
        row.classList.add('checked-row');
      }
      
      // Efecto confeti de corazones al cumplir plan en su coordenada
      for (let i = 0; i < 15; i++) {
        const heart = document.createElement('div');
        heart.className = 'fixed pointer-events-none z-50 text-purple-500/80';
        
        // Centrar alrededor de la tarjeta
        const rect = card.getBoundingClientRect();
        heart.style.left = `${rect.left + rect.width/2 + (Math.random() - 0.5) * 100}px`;
        heart.style.top = `${rect.top + rect.height/2 + (Math.random() - 0.5) * 100}px`;
        
        heart.innerHTML = `
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
        `;
        
        document.body.appendChild(heart);
        
        const xOffset = (Math.random() - 0.5) * 200;
        const yOffset = -150 - Math.random() * 100;
        
        heart.animate([
          { transform: 'translate(0, 0) scale(1)', opacity: 0.9 },
          { transform: `translate(${xOffset}px, ${yOffset}px) scale(1.8)`, opacity: 0 }
        ], {
          duration: 1500,
          easing: 'ease-out',
          fill: 'forwards'
        });
        
        setTimeout(() => heart.remove(), 1500);
      }
    } else {
      badge.textContent = "Por vivir juntos ✦";
      if (row) {
        row.classList.remove('checked-row');
      }
    }
  }
</script>
