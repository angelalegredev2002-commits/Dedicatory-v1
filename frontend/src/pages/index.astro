    <!-- SVG pulsing Heart instead of Emoji -->
    <svg class="w-6 h-6 text-purple-500 mx-auto mb-3 animate-pulse" fill="currentColor" viewBox="0 0 24 24">
      <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
    </svg>
    <p class="tracking-wider">© 2026 Sakad Technology · Todos los derechos reservados</p>
    <p class="text-xs text-gray-700 mt-1">Hecho con amor · Para {dedicatoria.para}</p>
