---
import Layout from '../layouts/Layout.astro';

// ══════════════════════════════════════════════
// PERSONALIZA AQUÍ TU DEDICATORIA
// ══════════════════════════════════════════════

const dedicatoria = {
  para: "Lesly",                        // Nombre de la persona
  de:   "Con todo mi corazón",
  mensaje: `Hay palabras que a veces no sé cómo expresar, pero hoy quiero intentarlo desde lo más profundo de mi ser. Me enamoré de ti completamente, de una manera que nunca creí posible, y quiero serte siempre leal.

Me encanta absolutamente todo de ti. Me encantan tus caricias que me dan paz, tu mirada, tu forma de ser, y hasta cuando te pones "celosita" te ves hermosa. Existen mil y un formas de decirte que te amo, y quiero pasar mi vida demostrártelas todas.

Quizá a veces no sea el hombre más detallista, ni el caballero perfecto que dicen las historias, pero soy alguien muy humilde que te entrega su alma entera sin dudarlo. Alguien que haría lo que fuera solo por cuidarte y verte feliz.

Gracias por existir, gracias por quedarte a mi lado. Te amo infinitamente.`,
  // Pon la fecha de vuestro aniversario o fecha especial aquí (Formato: AAAA-MM-DD)
  fechaInicio: "2026-04-18", 
};

// Canciones: Morat - Aprender A Quererte
const canciones = [
  {
    titulo:  "Aprender a Quererte",
    artista: "Morat",
    src:     "/music/Morat_-_Aprender_A_Quererte_(SkySound.cc).mp3",
    cover:   "", // Opcional: pon una imagen de portada si quieres
    letras: [
      { t: 0,   texto: "..." },
      { t: 11,  texto: "Cuando te vi sentí algo raro por dentro" },
      { t: 15,  texto: "Una mezcla de miedo con locura" },
      { t: 19,  texto: "Y tu mirada me juró que si te pierdo" },
      { t: 22,  texto: "Habré perdido la más grande fortuna" },
      { t: 26,  texto: "No sé nada de tu historia ni de tu filosofía" },
      { t: 30,  texto: "Hoy te escribo sin pensar y sin ortografía" },
      { t: 34,  texto: "Para aprender a quererte" },
      { t: 38,  texto: "Voy a estudiar cómo se cumplen tus sueños" },
      { t: 42,  texto: "Voy a leerte siempre muy lentamente" },
      { t: 46,  texto: "Quiero entenderte" },
      { t: 50,  texto: "Cuando te vi tuve un buen presentimiento" },
      { t: 54,  texto: "De esos que llegan una vez en la vida" },
      { t: 57,  texto: "Quiero tenerte aunque sea solo un momentito" },
      { t: 61,  texto: "Y si me dejas, tal vez todos los días" },
      { t: 65,  texto: "No sé nada de tu historia ni de tu filosofía" },
      { t: 69,  texto: "Hoy te escribo sin pensar y sin ortografía" },
      { t: 73,  texto: "Para aprender a quererte" },
      { t: 77,  texto: "Voy a estudiar cómo se cumplen tus sueños" },
      { t: 80,  texto: "Voy a leerte siempre muy lentamente" },
      { t: 84,  texto: "Quiero entenderte" },
      { t: 88,  texto: "Para enseñarte a extrañarme" },
      { t: 92,  texto: "Voy a escribirte mi canción más honesta" },
      { t: 96,  texto: "Darte una vida con más sumas que restas" },
      { t: 100, text: "Si tú me dejas, no habrá preguntas, solo respuestas" },
      { t: 104, texto: "No descansaré, solo quiero tenerte a mi lado" },
      { t: 112, texto: "Ruego que mi voz te demuestre lo que te he esperado" },
      { t: 120, texto: "Antes de estar junto a ti por toda la vida" },
      { t: 128, texto: "Quiero aprender a quererte" },
      { t: 132, texto: "Quiero estudiar cómo se cumplen tus sueños" },
      { t: 136, texto: "Voy a leerte siempre muy lentamente" },
      { t: 140, texto: "Quiero entenderte" },
      { t: 146, texto: "..." }
    ],
  },
];

// Fotos: coloca los archivos en /public/fotos/
const fotos: string[] = [];
---

<Layout title={`Para ${dedicatoria.para}`} description="Una dedicatoria especial con amor">

  <!-- ══ FONDO: Letras flotantes ══ -->
  <div id="flotantes" class="fixed inset-0 overflow-hidden pointer-events-none z-0"></div>

  <!-- ══ HERO ══ -->
  <section class="relative z-10 min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <p class="text-purple-400 text-sm font-light tracking-[0.4em] uppercase mb-6 flex items-center gap-2 justify-center">
      <svg class="w-4 h-4 animate-pulse" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.4 4.8 5.6.8-4 4 1 5.4-5-2.8-5 2.8 1-5.4-4-4 5.6-.8z"/></svg>
      Un rinconcito de amor solo para ti
      <svg class="w-4 h-4 animate-pulse" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.4 4.8 5.6.8-4 4 1 5.4-5-2.8-5 2.8 1-5.4-4-4 5.6-.8z"/></svg>
    </p>
    <h1 class="glow-text font-black leading-tight mb-4 flex flex-col items-center justify-center">
      <span class="text-white text-5xl md:text-7xl mb-2">Para ti, mi amor</span>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 via-fuchsia-400 to-pink-400 text-7xl md:text-[10rem] leading-none">
        {dedicatoria.para}
      </span>
    </h1>
    <div class="flex items-center gap-3 justify-center mt-4">
      <p class="text-gray-400 text-xl tracking-widest">{dedicatoria.de}</p>
      <svg class="w-5 h-5 text-purple-500 animate-pulse" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
    </div>

    <div class="mt-16 flex flex-col items-center gap-2 text-gray-500 text-sm animate-bounce">
      <span>Desliza hacia abajo pliss</span>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- ══ MENSAJE CON SOBRE INTERACTIVO ══ -->
  <section class="relative z-10 py-28 px-6">
    <div class="max-w-2xl mx-auto flex flex-col items-center">
      
      <p class="text-purple-400 text-sm font-semibold tracking-widest uppercase mb-12 text-center">
        Tengo una cartita guardada para ti... ¿la abres, pliss? ✨
      </p>

      <div class="envelope-container w-full flex justify-center pb-[28rem] pt-[10rem]">
        <div id="sobre" class="envelope flex items-center justify-center">
          
          <!-- Flap (tapa) del sobre -->
          <div class="envelope-flap"></div>
          
          <!-- Pocket (bolsillo frontal) del sobre -->
          <div class="envelope-pocket"></div>
          
          <!-- Sello lacrado del sobre (Corazón SVG en el centro) -->
          <div id="sello" class="absolute z-10 transition-all duration-500 flex items-center justify-center bg-gray-900 border border-white/20 w-14 h-14 rounded-full shadow-lg">
            <svg class="w-7 h-7 text-purple-500 animate-pulse" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
          </div>

          <!-- Carta que desliza hacia arriba -->
          <div class="envelope-letter flex flex-col items-center justify-center text-center">
            <span class="text-purple-400 text-2xl mb-4 font-serif">❝</span>
            <p class="text-gray-200 text-base md:text-lg leading-relaxed whitespace-pre-line italic font-serif">
              {dedicatoria.mensaje}
            </p>
            <span class="text-purple-400 text-2xl mt-4 font-serif">❞</span>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ══ LÍNEA DEL TIEMPO DE NUESTROS MOMENTOS ══ -->
  <section class="relative z-10 py-16 px-6">
    <div class="max-w-xl mx-auto">
      <h2 class="text-3xl font-bold text-white text-center mb-16 flex items-center justify-center gap-3">
        <!-- SVG History icon -->
        <svg class="w-7 h-7 text-fuchsia-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
        El camino que estamos dibujando...
      </h2>
      
      <div class="relative border-l-2 border-purple-500/30 pl-8 ml-4 space-y-12">
        <!-- Hito 1 -->
        <div class="relative">
          <span class="absolute -left-[41px] top-1.5 bg-purple-500 w-5 h-5 rounded-full border-4 border-gray-950 shadow-[0_0_10px_#c084fc]"></span>
          <time class="text-xs text-purple-400 font-semibold uppercase tracking-widest">18 de Abril de 2026</time>
          <h3 class="text-white text-lg font-bold mt-1 font-sans">El día que todo cambió</h3>
          <p class="text-gray-400 text-sm mt-2 leading-relaxed">
            El día más bonito de todos. Cuando empezamos a compartir sonrisas y decidimos tomarnos de la mano para no soltarnos jamás.
          </p>
        </div>
        
        <!-- Hito 2 -->
        <div class="relative">
          <span class="absolute -left-[41px] top-1.5 bg-purple-500 w-5 h-5 rounded-full border-4 border-gray-950 shadow-[0_0_10px_#c084fc]"></span>
          <time class="text-xs text-purple-400 font-semibold uppercase tracking-widest">Cada segundito...</time>
          <h3 class="text-white text-lg font-bold mt-1 font-sans">Coleccionando risas</h3>
          <p class="text-gray-400 text-sm mt-2 leading-relaxed">
            Todas las conversaciones, los chistes tontos que solo nosotros entendemos y cada pequeño detalle que me hace quererte más.
          </p>
        </div>

        <!-- Hito 3 -->
        <div class="relative">
          <span class="absolute -left-[41px] top-1.5 bg-fuchsia-500 w-5 h-5 rounded-full border-4 border-gray-950 shadow-[0_0_10px_#e879f9] animate-pulse"></span>
          <time class="text-xs text-fuchsia-400 font-semibold uppercase tracking-widest">Lo que viene...</time>
          <h3 class="text-white text-lg font-bold mt-1 font-sans">Mil aventuras más</h3>
          <p class="text-gray-400 text-sm mt-2 leading-relaxed">
            Este es solo el inicio de un viaje hermoso. Aún nos quedan millones de páginas por escribir y risas por compartir juntos.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ CONTADOR DE TIEMPO PREMIUM ══ -->
  <section class="relative z-10 py-12 px-6">
    <div class="max-w-xl mx-auto">
      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 text-center shadow-2xl">
        <h3 class="text-purple-400 text-sm font-semibold tracking-widest uppercase mb-6 flex items-center justify-center gap-2">
          <svg class="w-4 h-4 animate-spin-slow text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          El tiempo vuela cuando soy feliz a tu lado...
        </h3>
        <div class="grid grid-cols-4 gap-3 text-center">
          <div class="bg-black/30 border border-white/5 rounded-2xl p-3">
            <span id="c-dias" class="text-3xl md:text-4xl font-extrabold text-white glow-text">00</span>
            <p class="text-gray-400 text-[10px] mt-1 uppercase tracking-wider font-light">Días</p>
          </div>
          <div class="bg-black/30 border border-white/5 rounded-2xl p-3">
            <span id="c-horas" class="text-3xl md:text-4xl font-extrabold text-white glow-text">00</span>
            <p class="text-gray-400 text-[10px] mt-1 uppercase tracking-wider font-light">Horas</p>
          </div>
          <div class="bg-black/30 border border-white/5 rounded-2xl p-3">
            <span id="c-mins" class="text-3xl md:text-4xl font-extrabold text-white glow-text">00</span>
            <p class="text-gray-400 text-[10px] mt-1 uppercase tracking-wider font-light">Min</p>
          </div>
          <div class="bg-black/30 border border-white/5 rounded-2xl p-3">
            <span id="c-segs" class="text-3xl md:text-4xl font-extrabold text-white glow-text">00</span>
            <p class="text-gray-400 text-[10px] mt-1 uppercase tracking-wider font-light">Seg</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ REPRODUCTOR ══ -->
  <section class="relative z-10 py-20 px-6">
    <div class="max-w-lg mx-auto">
      <h2 class="text-3xl font-bold text-white text-center mb-12 flex items-center justify-center gap-3">
        <!-- SVG Note Icon -->
        <svg class="w-8 h-8 text-fuchsia-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 10l12-3M9 14a3 3 0 11-6 0 3 3 0 016 0zm12 2a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Nuestra melodía favorita
      </h2>

      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl">

        <!-- Portada -->
        <div id="album-art"
          class="w-44 h-44 mx-auto rounded-2xl mb-7 shadow-2xl flex items-center justify-center overflow-hidden
                 bg-gradient-to-br from-purple-600 via-fuchsia-500 to-pink-600 relative transition-transform duration-500">
          <!-- SVG Music Icon inside Album -->
          <svg id="album-svg" class="w-16 h-16 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 10l12-3M9 14a3 3 0 11-6 0 3 3 0 016 0zm12 2a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>

        <!-- Info -->
        <div class="text-center mb-6">
          <p class="text-white text-xl font-bold font-sans" id="song-title">Cargando...</p>
          <p class="text-gray-400 text-sm mt-1"   id="song-artist"></p>
        </div>

        <!-- Barra progreso -->
        <div class="mb-5">
          <div class="flex justify-between text-gray-500 text-xs mb-1">
            <span id="t-actual">0:00</span>
            <span id="t-total">0:00</span>
          </div>
          <div id="barra-prog"
            class="w-full h-2 bg-white/10 rounded-full cursor-pointer group relative">
            <div id="barra-fill"
              class="h-2 rounded-full bg-gradient-to-r from-pink-500 to-purple-500 transition-all duration-200"
              style="width:0%"></div>
          </div>
        </div>

        <!-- Controles -->
        <div class="flex items-center justify-center gap-8 mb-8">
          <button id="btn-prev"
            class="text-gray-400 hover:text-fuchsia-400 transition-colors flex items-center justify-center w-10 h-10 rounded-full hover:bg-white/5 cursor-pointer select-none">
            <!-- SVG Prev -->
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6 19h2V5H6v14zm12-14l-8 7 8 7V5z"/>
            </svg>
          </button>

          <button id="btn-play"
            class="w-16 h-16 rounded-full bg-gradient-to-r from-purple-500 to-fuchsia-600
                   flex items-center justify-center shadow-lg shadow-pink-500/30
                   hover:scale-110 active:scale-95 transition-transform cursor-pointer select-none">
            <!-- SVG Play initially -->
            <span id="play-icon-wrapper" class="flex items-center justify-center">
              <svg class="w-6 h-6 text-white translate-x-[2px]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </span>
          </button>

          <button id="btn-next"
            class="text-gray-400 hover:text-fuchsia-400 transition-colors flex items-center justify-center w-10 h-10 rounded-full hover:bg-white/5 cursor-pointer select-none">
            <!-- SVG Next -->
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M16 5v14h2V5h-2zm-12 14l8-7-8-7v14z"/>
            </svg>
          </button>
        </div>

        <!-- Letras de la canción -->
        <div class="bg-black/40 border border-white/5 rounded-2xl p-5 min-h-[90px] flex items-center justify-center">
          <p id="lyric-display"
            class="lyric-line text-center text-white text-base md:text-lg font-medium leading-relaxed px-2 font-serif">
            Dale play y cantemos juntos...
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ PILA DE CARTAS 3D INTERACTIVAS (TINDER DE RECUERDOS - ULTRA-SUAVE Y FLUIDO) ══ -->
  <section class="relative z-10 py-24 px-6 overflow-hidden">
    <div class="max-w-4xl mx-auto flex flex-col items-center">
      <h2 class="text-3xl font-bold text-white text-center mb-4 flex items-center justify-center gap-3">
        <!-- SVG Sparkles / Flower Icon -->
        <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 21l-.813-5.096L3.096 15.187 8.192 14.37 9 9.278l.808 5.093 5.096.817-5.091.816zM19.813 6.904L19 12l-.813-5.096-5.091-.717 5.091-.817.813-5.096.808 5.093 5.096.817-5.091.816z"/>
        </svg>
        Momentos que guardo en el corazón
      </h2>
      <p class="text-gray-400 text-center mb-16 text-sm max-w-md mx-auto">
        Una cajita de recuerdos mágicos. Toca la carta de adelante para leer lo que te escribí, o usa los botones para ir al siguiente recuerdo.
      </p>
      
      <!-- Contenedor del Deck 3D -->
      <div id="galeria-stack" class="stack-container mb-12">
        <!-- Rellenado dinámicamente con JS -->
      </div>

      <!-- Controles del Deck -->
      <div class="flex items-center gap-6 mt-4">
        <button id="btn-stack-prev"
          class="w-12 h-12 rounded-full border border-white/10 hover:border-pink-500/50 bg-white/5 hover:bg-white/10 text-white flex items-center justify-center transition-all duration-300 hover:scale-105 active:scale-95 cursor-pointer shadow-lg">
          <!-- SVG Arrow Left -->
          <svg class="w-5 h-5 text-gray-300 hover:text-fuchsia-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
          </svg>
        </button>

        <button id="btn-stack-next"
          class="px-6 h-12 rounded-full bg-gradient-to-r from-pink-500 to-rose-600 text-white font-semibold flex items-center gap-2 hover:scale-105 active:scale-95 transition-all duration-300 shadow-lg shadow-pink-500/20 cursor-pointer">
          <span>Siguiente Recuerdo</span>
          <!-- SVG Arrow Right -->
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
          </svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ══ NUESTRO MAPA DE AVENTURAS CON CAMINO DE RUTA INTERACTIVO ══ -->
  <section class="relative z-10 py-24 px-6 overflow-hidden">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-white text-center mb-4 flex items-center justify-center gap-3">
        <!-- SVG Map/Compass Icon -->
        <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.61c-.38.19-.622.58-.622 1.006v11.162c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/>
        </svg>
        Nuestras próximas locuras juntos
      </h2>
      <p class="text-gray-400 text-center mb-20 text-sm max-w-md mx-auto">
        Un mapa interactivo con todo lo que prometo que haremos juntos. Cuando cumplamos uno, ¡toca la tarjeta para tacharlo!
      </p>

      <!-- Contenedor del Mapa con Lineamiento -->
      <div class="adventure-path-container">
        <!-- Línea discontinua que conecta todos los hitos del mapa -->
        <div class="adventure-trail-line"></div>

        <!-- Parada 1: Viaje Soñado -->
        <div class="adventure-path-row">
          <div class="adventure-path-node">1</div>
          <div class="adventure-card group" onclick="toggleAdventure(this)">
            <div class="heart-checkbox">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
              </svg>
            </div>
            <span class="adventure-badge">Por vivir juntos ✦</span>
            <div class="adventure-icon">
              <!-- Airplane SVG -->
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>
              </svg>
